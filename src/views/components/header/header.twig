{# ================================================================
   HEADER COMPONENT
   ================================================================
   Sticky header with logo, search, cart, and user actions
   Mobile-optimized with 44px tap targets
   ================================================================ #}

<header class="site-header">
    <div class="container">
        <div class="header-inner">
            {# Logo #}
            <a href="{{ store.url }}" class="header-logo">
                {% if store.logo %}
                    <img src="{{ store.logo }}" alt="{{ store.name }}" loading="eager">
                {% else %}
                    <span>{{ store.name }}</span>
                {% endif %}
            </a>

            {# Actions #}
            <div class="header-actions">
                {# Search #}
                <button class="header-icon" onclick="salla.event.dispatch('search::open')" aria-label="بحث">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.3-4.3"></path>
                    </svg>
                </button>

                {# Wishlist #}
                <a href="/wishlist" class="header-icon" aria-label="المفضلة">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
                    </svg>
                </a>

                {# Cart #}
                <a href="/cart" class="header-icon" aria-label="سلة التسوق" style="position: relative;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8" cy="21" r="1"></circle>
                        <circle cx="19" cy="21" r="1"></circle>
                        <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                    </svg>
                    <salla-cart-summary widget-counter></salla-cart-summary>
                </a>

                {# User #}
                {% if user.type == 'guest' %}
                    <button class="header-icon" onclick="salla.event.dispatch('login::open')" aria-label="تسجيل الدخول">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </button>
                {% else %}
                    <a href="/profile" class="header-icon" aria-label="حسابي">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</header>
