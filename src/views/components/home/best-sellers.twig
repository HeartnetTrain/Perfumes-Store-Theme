{# ================================================================
   🏆 BEST SELLERS SECTION
   ================================================================
   Purpose: Showcase top products with social proof (ratings)
   CRO: Quick add-to-cart, star ratings, sale badges
   Uses: salla-product-card web component for cart functionality
   ================================================================ #}

<section class="section-padding" id="best-sellers" style="background: var(--color-bg);">
    <div class="container">
        {# Section Header #}
        <h2 class="section-title">الأكثر <span class="gold-gradient">مبيعاً</span></h2>
        <p class="section-subtitle">اختيارات عملائنا المفضلة</p>

        {# Products Grid - Uses Salla's product list component #}
        <salla-product-list 
            source="best-selling" 
            limit="8"
            class="products-grid">
        </salla-product-list>

        {# Fallback: Manual product cards if not using web component #}
        {# 
        <div class="products-grid">
            {% for product in products %}
                <div class="product-card">
                    <a href="{{ product.url }}" class="product-card-image">
                        <img src="{{ product.image.url }}" 
                             alt="{{ product.image.alt|default(product.name) }}" 
                             loading="lazy"
                             width="400" 
                             height="400">
                        {% if product.is_on_sale %}
                            <span class="product-card-badge">{{ product.discount_percentage }}</span>
                        {% endif %}
                    </a>
                    <div class="product-card-body">
                        <a href="{{ product.url }}">
                            <h3 class="product-card-name">{{ product.name }}</h3>
                        </a>
                        
                        {% if product.rating %}
                        <div class="product-card-rating">
                            {% for i in 1..5 %}
                                {% if i <= product.rating.stars %}
                                    <span class="star">★</span>
                                {% else %}
                                    <span class="star star-empty">★</span>
                                {% endif %}
                            {% endfor %}
                            <span style="font-size: 0.75rem; color: var(--color-text-muted);">({{ product.rating.count }})</span>
                        </div>
                        {% endif %}

                        <div class="product-card-price">
                            {% if product.is_on_sale %}
                                <span class="price-current">{{ product.sale_price|money }}</span>
                                <span class="price-old">{{ product.regular_price|money }}</span>
                            {% else %}
                                <span class="price-current">{{ product.price|money }}</span>
                            {% endif %}
                        </div>

                        <salla-add-product-button product-id="{{ product.id }}" class="product-card-btn">
                            أضف إلى السلة
                        </salla-add-product-button>
                    </div>
                </div>
            {% endfor %}
        </div>
        #}

        {# View All CTA #}
        <div style="text-align: center; margin-top: 40px;">
            <a href="/products" class="btn btn-outline btn-lg">
                عرض جميع المنتجات
            </a>
        </div>
    </div>
</section>
