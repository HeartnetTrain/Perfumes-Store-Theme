{# ================================================================
   🎯 HERO SECTION - Above the Fold
   ================================================================
   Purpose: Strong first impression, luxury branding, immediate CTA
   CRO: Trust badges visible, clear value proposition, single CTA
   ================================================================ #}

<section class="hero">
    <div class="container">
        <div class="hero-content animate-in">
            {# Premium Badge #}
            <span class="hero-badge">✨ عطور أصلية 100%</span>

            {# Main Headline #}
            <h1 class="hero-title">
                عطور <span class="gold-gradient">فاخرة</span> تدوم طويلاً
            </h1>

            {# Subheadline - Value Proposition #}
            <p class="hero-subtitle">
                اكتشف مجموعتنا الحصرية من أرقى العطور العربية والفرنسية. 
                ثبات يدوم أكثر من ١٢ ساعة مع تركيبات فريدة تليق بذوقك الرفيع.
            </p>

            {# CTA Buttons #}
            <div class="hero-cta-group">
                <a href="/products" class="btn btn-primary btn-lg">
                    تسوق الآن
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                </a>
                <a href="#best-sellers" class="btn btn-outline btn-lg">
                    الأكثر مبيعاً
                </a>
            </div>

            {# Trust Badges - Immediately Visible #}
            <div class="hero-trust">
                <div class="hero-trust-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                    <span>عطور أصلية مضمونة</span>
                </div>
                <div class="hero-trust-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                        <line x1="1" y1="10" x2="23" y2="10"></line>
                    </svg>
                    <span>الدفع عند الاستلام</span>
                </div>
                <div class="hero-trust-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                    <span>شحن سريع</span>
                </div>
            </div>
        </div>
    </div>
</section>
