{# ================================================================
   FOOTER COMPONENT
   ================================================================ #}

<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            {# Brand Column #}
            <div>
                <div class="footer-brand">{{ store.name }}</div>
                <p class="footer-desc">
                    {{ store.description|default('عطور فاخرة تدوم طويلاً. نقدم لك أفضل العطور العربية والعالمية بأسعار تنافسية مع شحن سريع لجميع مناطق المملكة.') }}
                </p>
            </div>

            {# Quick Links #}
            <div>
                <h3 class="footer-heading">روابط سريعة</h3>
                <ul class="footer-links">
                    <li><a href="/">الرئيسية</a></li>
                    <li><a href="/products">جميع المنتجات</a></li>
                    <li><a href="/pages/about">من نحن</a></li>
                    <li><a href="/pages/contact">اتصل بنا</a></li>
                    <li><a href="/pages/shipping-policy">سياسة الشحن</a></li>
                    <li><a href="/pages/return-policy">سياسة الاسترجاع</a></li>
                </ul>
            </div>

            {# Contact Info #}
            <div>
                <h3 class="footer-heading">تواصل معنا</h3>
                <ul class="footer-links">
                    {% if store.contacts.email %}
                        <li>
                            <a href="mailto:{{ store.contacts.email }}">{{ store.contacts.email }}</a>
                        </li>
                    {% endif %}
                    {% if store.contacts.whatsapp %}
                        <li>
                            <a href="https://wa.me/{{ store.contacts.whatsapp }}" target="_blank" rel="noopener">
                                واتساب: {{ store.contacts.whatsapp }}
                            </a>
                        </li>
                    {% endif %}
                    {% if store.contacts.mobile %}
                        <li>
                            <a href="tel:{{ store.contacts.mobile }}">{{ store.contacts.mobile }}</a>
                        </li>
                    {% endif %}
                </ul>

                {# Social Media #}
                <div style="display: flex; gap: 12px; margin-top: 16px;">
                    {% if store.social.instagram %}
                        <a href="{{ store.social.instagram }}" target="_blank" rel="noopener" class="header-icon" aria-label="Instagram" style="width:36px;height:36px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
                        </a>
                    {% endif %}
                    {% if store.social.twitter %}
                        <a href="{{ store.social.twitter }}" target="_blank" rel="noopener" class="header-icon" aria-label="Twitter" style="width:36px;height:36px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                    {% endif %}
                    {% if store.social.snapchat %}
                        <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener" class="header-icon" aria-label="Snapchat" style="width:36px;height:36px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.166 3c.796 0 3.495.223 4.769 3.073.426.953.322 2.559.24 3.867l-.012.193c-.006.087-.011.174-.015.26.198.106.42.16.664.16.19 0 .369-.04.535-.091a.96.96 0 0 1 .3-.052c.166 0 .32.042.46.126.27.163.376.44.376.66 0 .393-.34.687-.774.862-.088.035-.214.073-.36.117-.33.1-.784.237-.928.424-.09.117-.1.27-.028.477l.007.02c.404 1.063 1.09 1.96 1.985 2.598.285.204.606.37.942.491.17.06.287.153.35.277.088.176.032.376-.16.578a2.312 2.312 0 0 1-.577.375 5.229 5.229 0 0 1-.996.36c-.063.016-.12.04-.175.072-.134.079-.163.196-.194.318l-.006.024c-.033.124-.076.288-.31.456-.257.185-.617.26-.993.337-.33.068-.671.138-.983.275-.181.08-.341.2-.515.33-.393.296-.88.664-1.783.664-.047 0-.095-.002-.144-.005a4.004 4.004 0 0 1-.17.005c-.904 0-1.39-.368-1.784-.664a3.057 3.057 0 0 0-.515-.33c-.312-.137-.653-.207-.984-.275-.375-.077-.735-.152-.992-.337-.234-.168-.277-.332-.31-.456l-.006-.024c-.031-.122-.06-.24-.194-.318a.67.67 0 0 0-.175-.072 5.229 5.229 0 0 1-.997-.36 2.312 2.312 0 0 1-.576-.375c-.192-.202-.248-.402-.16-.578.062-.124.18-.216.35-.277.336-.12.657-.287.942-.49a5.164 5.164 0 0 0 1.985-2.599l.007-.02c.072-.207.062-.36-.028-.477-.144-.187-.598-.325-.928-.424a5.463 5.463 0 0 1-.36-.117c-.434-.175-.774-.47-.774-.862 0-.22.106-.497.376-.66a.89.89 0 0 1 .46-.126.96.96 0 0 1 .3.052c.166.051.345.091.535.091.244 0 .466-.054.664-.16a10.6 10.6 0 0 1-.015-.26l-.012-.193c-.082-1.308-.186-2.914.24-3.867C8.505 3.223 11.204 3 12 3h.166z"/></svg>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Bottom Bar #}
        <div class="footer-bottom">
            <p>جميع الحقوق محفوظة &copy; {{ "now"|date("Y") }} {{ store.name }}</p>
            {% if store.settings.tax.number %}
                <p style="margin-top: 8px;">الرقم الضريبي: {{ store.settings.tax.number }}</p>
            {% endif %}
        </div>
    </div>
</footer>
