{# ================================================================
   🏪 SALLA PREMIUM PERFUME THEME - Master Layout
   ================================================================
   Luxury perfume e-commerce theme optimized for Saudi market
   - Mobile-first responsive design
   - Full RTL (Arabic-first) support
   - High-conversion focused layout
   - Black & Gold luxury color scheme
   ================================================================ #}

{{ theme.settings.set('placeholder', 'images/placeholder.png') }}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <meta name="theme-color" content="#0a0a0a">
    <meta name="description" content="{{ store.description }}">
    
    <title>{{ page.title }} | {{ store.name }}</title>
    
    <link rel="icon" href="{{ store.icon }}">
    
    {# Font - Premium Arabic Typography #}
    {% if theme.font %}
        <link rel="stylesheet" href="{{ theme.font.url }}">
    {% else %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
    {% endif %}

    {# Theme Primary Color CSS Variables #}
    <style>
        :root {
            --color-primary: {{ theme.color.primary|default('#c8a45c') }};
            --color-primary-dark: {{ theme.color.darker(0.2)|default('#a88a3c') }};
            --color-primary-light: {{ theme.color.lighter(0.3)|default('#dfc88a') }};
            --color-text: {{ theme.color.text|default('#ffffff') }};
            --color-bg: #0a0a0a;
            --color-bg-secondary: #141414;
            --color-bg-card: #1a1a1a;
            --color-border: #2a2a2a;
            --color-text-muted: #888888;
            --color-success: #22c55e;
            --color-white: #ffffff;
            --font-family: {% if theme.font %}'{{ theme.font.name }}'{% else %}'Tajawal'{% endif %}, sans-serif;
        }
    </style>
    
    {# Main Stylesheet #}
    <link rel="stylesheet" href="{{ 'assets/styles/app.css' | asset }}">
    
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <salla-product-card-toast></salla-product-card-toast>
    {% endif %}

    {% block head_scripts %}{% endblock %}
    
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}
    
    {# Tracking services, custom CSS #}
    {% hook 'head:end' %}
</head>

<body class="perfume-theme font-primary bg-body text-white antialiased">
    {% hook 'body:start' %}
    
    {# ===== HEADER ===== #}
    {% component 'header.header' %}
    
    {# ===== MAIN CONTENT ===== #}
    <main id="main-content">
        {% block content %}{% endblock %}
    </main>
    
    {# ===== FOOTER ===== #}
    {% component 'footer.footer' %}
    
    {# ===== FLOATING WHATSAPP BUTTON (Sticky) ===== #}
    {% if store.contacts.whatsapp %}
    <a href="https://wa.me/{{ store.contacts.whatsapp }}?text={{ 'مرحبا، أريد الاستفسار عن هذا المنتج'|url_encode }}" 
       target="_blank"
       rel="noopener noreferrer"
       class="whatsapp-float"
       aria-label="تواصل معنا عبر واتساب">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.917 1.04 5.591 2.77 7.67L.96 24l4.478-1.77A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.6c-2.252 0-4.336-.744-6.018-2.002l-.43-.318-2.66 1.05.892-2.584-.35-.457A9.544 9.544 0 012.4 12c0-5.302 4.298-9.6 9.6-9.6 5.302 0 9.6 4.298 9.6 9.6 0 5.302-4.298 9.6-9.6 9.6z"/>
        </svg>
        <span class="whatsapp-text">تواصل معنا</span>
    </a>
    {% endif %}
    
    {% hook 'body:end' %}
    
    {% if theme.settings.get('enable_add_product_toast', true) %}
        <salla-product-card-toast position="bottom-start"></salla-product-card-toast>
    {% endif %}
    
    {# Twilight Components #}
    <salla-search-component></salla-search-component>
    
    {% if user.type == 'guest' %}
        <salla-login-modal></salla-login-modal>
    {% endif %}
    
    {% if store.scope %}
        <salla-scopes></salla-scopes>
    {% endif %}
    
    {% block scripts %}{% endblock %}
</body>
</html>
