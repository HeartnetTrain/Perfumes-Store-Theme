{# ================================================================
   🛍️ SINGLE PRODUCT PAGE - VERY IMPORTANT
   ================================================================
   High-converting product page with:
   - Image gallery with slider
   - Sticky add-to-cart (mobile)
   - Trust badges (COD, fast shipping)
   - Benefit bullets
   - Upsell section ("قد يعجبك أيضاً")
   
   Variables available:
   - product.name, product.price, product.sale_price, product.regular_price
   - product.image, product.images[], product.rating
   - product.description, product.brand, product.options
   - product.is_on_sale, product.is_available, product.quantity
   ================================================================ #}

{% extends "layouts.master" %}

{% block content %}
<div class="product-page">
    <div class="container">
        {# Breadcrumb #}
        <nav style="padding: 12px 0; font-size: 0.8125rem; color: var(--color-text-muted);">
            <a href="/" style="color: var(--color-text-muted);">الرئيسية</a>
            <span style="margin: 0 8px;">/</span>
            {% if product.category %}
                <a href="{{ product.category.url }}" style="color: var(--color-text-muted);">{{ product.category.name }}</a>
                <span style="margin: 0 8px;">/</span>
            {% endif %}
            <span style="color: var(--color-primary);">{{ product.name }}</span>
        </nav>

        {# ===== PRODUCT LAYOUT (Gallery + Info) ===== #}
        <div class="product-layout">
            
            {# ===== LEFT: Product Gallery ===== #}
            <div class="product-gallery">
                {# Main Image #}
                <div class="product-gallery-main">
                    <img src="{{ product.image.url }}" 
                         alt="{{ product.image.alt|default(product.name) }}" 
                         loading="eager"
                         id="main-product-image">
                    
                    {# Sale Badge #}
                    {% if product.is_on_sale %}
                        <span class="product-card-badge" style="font-size: 0.875rem; padding: 6px 14px;">
                            خصم {{ product.discount_percentage }}
                        </span>
                    {% endif %}
                </div>

                {# Thumbnails #}
                {% if product.images|length > 1 %}
                <div class="product-gallery-thumbs">
                    {% for image in product.images %}
                        <button class="product-gallery-thumb {% if loop.first %}active{% endif %}" 
                                onclick="document.getElementById('main-product-image').src='{{ image.url }}'; 
                                         document.querySelectorAll('.product-gallery-thumb').forEach(t => t.classList.remove('active')); 
                                         this.classList.add('active');"
                                aria-label="صورة المنتج {{ loop.index }}">
                            <img src="{{ image.url }}" 
                                 alt="{{ image.alt|default(product.name) }}" 
                                 loading="lazy"
                                 width="64" 
                                 height="64">
                        </button>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            {# ===== RIGHT: Product Info ===== #}
            <div class="product-info">
                {% hook 'product:single.description.start' %}

                {# Brand #}
                {% if product.brand.name %}
                    <a href="{{ product.brand.url }}" class="product-brand">{{ product.brand.name }}</a>
                {% endif %}

                {# Product Name #}
                <h1 class="product-name">{{ product.name }}</h1>

                {# Rating #}
                {% if product.rating %}
                <div class="product-rating-row">
                    <div style="display: flex; gap: 2px; color: var(--color-primary);">
                        {% for i in 1..5 %}
                            {% if i <= product.rating.stars %}
                                <span>★</span>
                            {% else %}
                                <span style="color: var(--color-border);">★</span>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <span style="font-size: 0.875rem; color: var(--color-text-muted);">
                        ({{ product.rating.count }} تقييم)
                    </span>
                </div>
                {% endif %}

                {# Price #}
                <div class="product-price-row">
                    {% if product.is_on_sale %}
                        <span class="product-price-current">{{ product.sale_price|money }}</span>
                        <span class="product-price-old">{{ product.regular_price|money }}</span>
                        <span class="product-discount-badge">خصم {{ product.discount_percentage }}</span>
                    {% else %}
                        <span class="product-price-current">
                            {{ product.starting_price ? product.starting_price|money : product.price|money }}
                        </span>
                    {% endif %}
                </div>

                {% if product.is_taxable %}
                    <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 16px;">
                        {{ trans('pages.products.tax_included') }}
                    </p>
                {% endif %}

                {# ===== BENEFIT BULLETS (CRO Critical) ===== #}
                <ul class="product-benefits">
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        يدوم طوال اليوم - ثبات أكثر من ١٢ ساعة
                    </li>
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        مناسب لجميع المناسبات
                    </li>
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        تركيبة فاخرة من مكونات طبيعية
                    </li>
                    <li>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        عطر أصلي ١٠٠٪ مع ضمان الجودة
                    </li>
                </ul>

                {# ===== TRUST BADGES (Product Page) ===== #}
                <div class="product-trust-badges">
                    <div class="product-trust-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                        الدفع عند الاستلام
                    </div>
                    <div class="product-trust-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="1" y="3" width="15" height="13"></rect>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                            <circle cx="5.5" cy="18.5" r="2.5"></circle>
                            <circle cx="18.5" cy="18.5" r="2.5"></circle>
                        </svg>
                        شحن سريع
                    </div>
                    <div class="product-trust-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="1 4 1 10 7 10"></polyline>
                            <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                        </svg>
                        استرجاع مجاني
                    </div>
                </div>

                {# ===== PRODUCT DESCRIPTION ===== #}
                {% set product_desc = product.description|replace({"<br>":"\n"}) %}
                {% if product.has_read_more %}
                    <div style="margin-bottom: 20px; color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.8; max-height: 120px; overflow: hidden;" id="product-desc">
                        {{ product_desc|raw }}
                    </div>
                    <button onclick="document.getElementById('product-desc').style.maxHeight='none'; this.style.display='none';" 
                            style="background: none; border: none; color: var(--color-primary); cursor: pointer; font-family: var(--font-family); font-weight: 600; margin-bottom: 20px;">
                        {{ trans('pages.products.read_more') }} ←
                    </button>
                {% else %}
                    <div style="margin-bottom: 20px; color: var(--color-text-muted); font-size: 0.9375rem; line-height: 1.8;">
                        {{ product_desc|raw }}
                    </div>
                {% endif %}

                {# ===== PRODUCT OPTIONS (Size, Color, etc.) ===== #}
                <salla-product-options product-id="{{ product.id }}"></salla-product-options>

                {# ===== QUANTITY + ADD TO CART ===== #}
                <div style="margin-top: 24px;">
                    {% if not product.is_hidden_quantity and product.type != 'booking' %}
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                        <label style="font-size: 0.875rem; font-weight: 600;">الكمية:</label>
                        <salla-quantity-input product-id="{{ product.id }}"></salla-quantity-input>
                    </div>
                    {% endif %}

                    {# Add to Cart Button - Full Width #}
                    <salla-add-product-button product-id="{{ product.id }}" class="btn btn-primary btn-full btn-lg">
                        {{ product.add_to_cart_label|default('أضف إلى السلة') }}
                    </salla-add-product-button>

                    {# Buy Now Button #}
                    <a href="/cart" class="btn btn-outline btn-full btn-lg" style="margin-top: 12px;">
                        اشتري الآن
                    </a>

                    {# Gifting #}
                    {% if product.is_giftable %}
                        <salla-gifting product-id="{{ product.id }}"></salla-gifting>
                    {% endif %}
                </div>

                {# ===== INSTALLMENT ===== #}
                <salla-installment product-id="{{ product.id }}"></salla-installment>

                {# Sold / Remaining info #}
                {% if product.sold_quantity or product.can_show_remained_quantity %}
                <div style="display: flex; gap: 16px; margin-top: 16px; font-size: 0.8125rem;">
                    {% if product.sold_quantity %}
                        <span style="color: var(--color-text-muted);">
                            🔥 تم بيع {{ product.sold_quantity }} قطعة
                        </span>
                    {% endif %}
                    {% if product.can_show_remained_quantity %}
                        <span style="color: #ef4444; font-weight: 600;">
                            ⚠️ متبقي {{ product.quantity }} فقط!
                        </span>
                    {% endif %}
                </div>
                {% endif %}

                {% hook 'product:single.description.end' %}
            </div>
        </div>

        {# ===== UPSELL: "قد يعجبك أيضاً" ===== #}
        <section class="section-padding">
            <h2 class="section-title">قد يعجبك <span class="gold-gradient">أيضاً</span></h2>
            <p class="section-subtitle">منتجات مختارة لك</p>
            
            <salla-product-list 
                source="related" 
                source-value="{{ product.id }}" 
                limit="4"
                class="products-grid">
            </salla-product-list>
        </section>

        {# ===== REVIEWS SECTION ===== #}
        {% if store.settings.rating.show_on_product %}
        <section class="section-padding" style="border-top: 1px solid var(--color-border);">
            <h2 class="section-title">تقييمات <span class="gold-gradient">العملاء</span></h2>
            <salla-product-comments product-id="{{ product.id }}"></salla-product-comments>
        </section>
        {% endif %}
    </div>
</div>

{# ===== STICKY ADD TO CART (Mobile Only) ===== #}
<div class="sticky-cart">
    <div class="sticky-cart-price">
        {% if product.is_on_sale %}
            {{ product.sale_price|money }}
        {% else %}
            {{ product.price|money }}
        {% endif %}
    </div>
    <salla-add-product-button product-id="{{ product.id }}" class="sticky-cart-btn">
        أضف إلى السلة
    </salla-add-product-button>
</div>

{% endblock %}

{% block scripts %}
<script>
// Simple image gallery - swap main image on thumb click
// Already handled inline for lightweight DOM
</script>
{% endblock %}
